{
  "name": "hagicode upptime",
  "entry": "./src/index.js",
  "installCommand": "git clone --depth=1 https://github.com/upptime/status-page.git status-page && CYPRESS_INSTALL_BINARY=0 npm ci --prefix status-page",
  "buildCommand": "npm run export --prefix status-page",
  "assets": {
    "directory": "./status-page/__sapper__/export",
    "notFoundStrategy": "singlePageApplication"
  }
}
